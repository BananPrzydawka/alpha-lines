apt-get update && apt-get install -y git curl build-essential tmux
curl -LsSf https://astral.sh/uv/install.sh | sh
source $HOME/.local/bin/env
git clone https://github.com/BananPrzydawka/alpha-lines ~/alpha-lines
cd ~/alpha-lines && uv sync
echo 'options nvidia NVreg_RestrictProfilingToAdminUsers=0' | tee /etc/modprobe.d/nvidia-profiler.conf
update-initramfs -u
reboot

ncu --profile-from-start off --target-processes all --set full -f -o alphalines_h100 uv run python script.py

TORCH_LOGS="aot" uv run main/only_model_speedtest.py
TORCH_LOGS="output_code" uv run main/only_model_speedtest.py 2> logs/compile/output.py

scp root@0.0.0.0:~/alpha-lines/logs/compile/output.py .